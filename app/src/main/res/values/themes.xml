<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZenDrive" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Status & Navigation bars -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>

        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>

        <!-- Accent / Secondary -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/primary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <!-- Text appearances -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Input style -->
        <item name="colorControlNormal">@color/text_hint</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="colorControlHighlight">@color/ripple</item>

        <!-- Dialog themes -->
        <item name="android:datePickerDialogTheme">@style/ZenDrive.DatePickerDialogTheme</item>

        <!-- FAB -->
        <item name="floatingActionButtonStyle">@style/ZenDrive.FAB</item>
    </style>

    <!-- Date Picker Dialog Theme -->
    <style name="ZenDrive.DatePickerDialogTheme" parent="Theme.MaterialComponents.Dialog">
        <item name="colorAccent">@color/accent</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:buttonBarButtonStyle">@style/ZenDrive.DatePickerButton</item>
    </style>

    <style name="ZenDrive.DatePickerButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- FAB style -->
    <style name="ZenDrive.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/fab_bg</item>
        <item name="tint">@color/fab_icon</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Card style -->
    <style name="ZenDrive.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Input field (outlined box) -->
    <style name="ZenDrive.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="hintTextColor">@color/accent</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Dropdown (exposed dropdown menu) -->
    <style name="ZenDrive.TextInputLayout.Dropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="hintTextColor">@color/accent</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Toolbar text -->
    <style name="ZenDrive.ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
